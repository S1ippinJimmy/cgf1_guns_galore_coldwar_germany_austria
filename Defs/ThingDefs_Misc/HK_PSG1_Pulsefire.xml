<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="CGF1_MWP_SemiAutoSniper_T1">
		<defName>CGF1_MWP_HK_PSG1_Pulsefire_</defName>
		<label>HK PSG1 Pulsefire</label>
		<description>Caliber: 7.62x51mm NATO. 20-round detachable mag. Semi-Automatic.
		
The Heckler &amp; Koch PSG1 (Präzisionsschützengewehr 1, or "precision marksman rifle 1") is a German designated marksman rifle first produced in 1972. It is built off of H&amp;K's G3 rifle, though it has been substantially modified with a strengthened receiver, a specialized sniping stock, an adjustable trigger, and a heavy free-floating match barrel providing an accuracy of better than 1 MOA. Factory PSG1 rifles are shipped with an attached Hensoldt ZF 6x42 scope. Fitted with a Pulsefire Under-Barrel Flamethrower (UBF.)</description>
		<graphicData>
			<texPath>CGF1/Gun/HK_PSG1_Pulsefire</texPath>
			<drawSize>1.02</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>90</Steel>
			<ComponentIndustrial>11</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>60000</WorkToMake>
			<Mass>8.7</Mass>
			<AccuracyTouch>0.55</AccuracyTouch>
			<AccuracyShort>0.70</AccuracyShort>
			<AccuracyMedium>0.80</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
		</statBases>
		<equippedAngleOffset>40</equippedAngleOffset>
		<weaponTags>
			<li>CGF1_Rifle_Marksman</li>
			<li>CGF1_Rifle_Marksman_Advanced</li>
			<li>CGF1_SniperRifle</li>
			<li>CGF1_SniperRifle_Advanced</li>
		</weaponTags>
		<weaponClasses>
			<li>LongShots</li>
			<li>RangedHeavy</li>
		</weaponClasses>
		<tradeTags>
			<li>CGF1_GunsGalore_ColdWarGermAus</li>
			<li>CGF1_GunsGalore_ColdWarGermAus_Sniper</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_762x51mmNATO_Sniper</defaultProjectile>
				<warmupTime>2</warmupTime>
				<range>44.9</range>
				<soundCast>CGF1_MWP_SFX_Rifle_Semi3</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<label>PSG1</label>
				<commandIcon>CGF1/Gun/HK_PSG1_Pulsefire</commandIcon>
			</li>
			<li>
				<verbClass>VEF.Weapons.Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Projectile_Flamethrower_Pulsefire</defaultProjectile>
				<warmupTime>2</warmupTime>
				<range>10.9</range>
				<burstShotCount>1</burstShotCount>
				<soundCast>CGF1_GG_SFXR_Flamethrower</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>14</muzzleFlashScale>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<onlyManualCast>true</onlyManualCast>
				<label>Pulsefire</label>
				<commandIcon>CGF1/Underbarrel/Pulsefire_UBF</commandIcon>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(0.6,0.6)</drawSize>
				<offsets>
					<li>(0.62,0.05)</li>
				</offsets>
			</li>
		</modExtensions>
		<comps>
			<li Class="MVCF.Comps.CompProperties_VerbProps">
				<compClass>MVCF.Comps.Comp_VerbProps</compClass>
				<verbProps>
					<li>
						<label>PSG1</label>
						<canBeToggled>true</canBeToggled>
						<separateToggle>false</separateToggle>
					</li>
					<li>
						<label>Pulsefire</label>
						<canBeToggled>true</canBeToggled>
						<separateToggle>false</separateToggle>
						<description>The Pulsefire Under-Barrel Flamethrower (UBF) is a portable incendiary projector that was designed to be mounted to various different weapon platforms, being compatible with standard picatinny and similar rail mounting configurations. It does not require a separate fuel tank or battery source, with the system being completely self-contained.</description>
					</li>
				</verbProps>
			</li>
		</comps>
		<generateCommonality>0.10</generateCommonality> <!-- Average -->
