			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>75</Steel>
			<ComponentIndustrial>10</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>55000</WorkToMake>
			<Mass>4.10</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
