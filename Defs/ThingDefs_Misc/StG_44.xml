<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="CGF1_MWP_AssaultRifle_T1">
		<defName>CGF1_MWP_StG_44_</defName>
		<label>StG-44</label>
		<description>Caliber: 7.92x33mm Kurz. 30-round detachable mag. Select-Fire.</description>
		<graphicData>
			<texPath>CGF1/Gun/StG_44</texPath>
			<drawSize>0.95</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T7_WW2Firearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>60</Steel>
			<ComponentIndustrial>7</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>40000</WorkToMake>
			<Mass>4.6</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
			<AccuracyShort>0.60</AccuracyShort>
			<AccuracyMedium>0.55</AccuracyMedium>
			<AccuracyLong>0.50</AccuracyLong>
			<RangedWeapon_Cooldown>1.7</RangedWeapon_Cooldown>
		</statBases>
		<equippedAngleOffset>40</equippedAngleOffset>
		<weaponTags>
			<li>CGF1_AR_Civilian</li>
			<li>CGF1_AR_Military</li>
		</weaponTags>
		<tradeTags>
			<li>CGF1_GunsGalore_ColdWarGermAus</li>
			<li>CGF1_GunsGalore_ColdWarGermAus_AR</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_792x33mmKurz_Auto</defaultProjectile>
				<warmupTime>1</warmupTime>
				<range>30.9</range>
				<burstShotCount>4</burstShotCount>
				<ticksBetweenBurstShots>9</ticksBetweenBurstShots>
				<soundCast>CGF1_GG_SFXR_Rifle3</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(0.7,0.7)</drawSize>
				<offsets>
					<li>(0.55,0.04)</li>
				</offsets>
			</li>
		</modExtensions>
		<generateCommonality>0.5</generateCommonality> <!-- Abundant -->
		<thingSetMakerTags>
			<li>CGF1_GunsGalore_RewardAncient_Common</li>
		</thingSetMakerTags>
	</ThingDef>
	
